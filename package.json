{
  "name": "conductor",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "bun run packages/core/src/server.ts",
    "dev:web": "pnpm --filter @conductor/web dev",
    "cli": "bun run packages/core/src/cli.ts",
    "build": "bun build packages/core/cli.ts --compile --outfile conductor",
    "build:web": "pnpm --filter @conductor/web build",
    "build:all": "pnpm build:web && pnpm build",
    "install:cli": "bun run build && cp conductor ~/.bun/bin/conductor && codesign --force --sign - ~/.bun/bin/conductor"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "workspaces": [
    "packages/*"
  ]
}
